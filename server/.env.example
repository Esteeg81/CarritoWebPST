DATABASE_URL="postgresql://user:password@localhost:5432/carritowebpst"
JWT_SECRET=replace-with-a-long-random-string
PORT=3001
# Email que se promueve automáticamente a rol ADMIN al registrarse/loguearse
ADMIN_EMAIL=owner@example.com
# Orígenes permitidos por CORS, separados por coma. Si no se define, solo
# permite localhost:5173 / localhost:5183 (uso local).
CORS_ORIGIN=https://esteeg81.github.io
# API key de Resend (resend.com) para avisar por mail al admin de pedidos
# nuevos y productos sin stock. Si no se define, esos avisos se omiten.
RESEND_API_KEY=
