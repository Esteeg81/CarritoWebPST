// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CUSTOMER
  ADMIN
}

enum OrderStatus {
  PENDIENTE
  CONFIRMADO
  ENVIADO
  ENTREGADO
  CANCELADO
}

model User {
  id           Int      @id @default(autoincrement())
  nombre       String
  email        String   @unique
  passwordHash String
  role         Role     @default(CUSTOMER)
  createdAt    DateTime @default(now())
  orders       Order[]
}

model Product {
  id        Int      @id @default(autoincrement())
  nombre    String
  precio    Float
  imagen    String
  stock     Int
  categoria String
  destacado Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Order {
  id        Int         @id @default(autoincrement())
  userId    Int
  user      User        @relation(fields: [userId], references: [id])
  total     Float
  status    OrderStatus @default(PENDIENTE)
  createdAt DateTime    @default(now())
  items     OrderItem[]
}

model OrderItem {
  id        Int    @id @default(autoincrement())
  orderId   Int
  order     Order  @relation(fields: [orderId], references: [id])
  productId Int
  nombre    String
  precio    Float
  cantidad  Int
}

model SiteSettings {
  id         Int      @id @default(1)
  fontFamily String   @default("sans-serif")
  textColor  String   @default("#1e293b")
  headerBg   String   @default("#0f172a")
  footerBg   String   @default("#ffffff")
  mainBg     String   @default("#f8fafc")
  updatedAt  DateTime @updatedAt
}
